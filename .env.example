# ─── App ───────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=itasset
POSTGRES_PASSWORD=itasset
POSTGRES_DB=itasset
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Used by the backend (async + sync drivers)
DATABASE_URL=postgresql+psycopg://itasset:itasset@db:5432/itasset

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Object storage (MinIO, S3-compatible) ─────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=it-asset
# Switch to a cloud: point S3_ENDPOINT at the provider's S3-compatible
# endpoint + set keys. AWS S3 / 阿里云 OSS need a region:
S3_REGION=
# Local MinIO auto-creates the bucket. On managed cloud the bucket is
# pre-provisioned and creds usually can't CreateBucket — set false:
S3_AUTO_CREATE_BUCKET=true

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720
# Bootstrap admin on first startup (idempotent). Both must be set to take effect.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=管理员

# ─── Lark / 飞书 ───────────────────────────────────────
# LARK_VARIANT controls API base + OAuth domain.
#   feishu -> open.feishu.cn / passport.feishu.cn   (国内飞书)
#   lark   -> open.larksuite.com / passport.larksuite.com (海外 Lark)
LARK_VARIANT=feishu
LARK_APP_ID=
LARK_APP_SECRET=
# Optional: chat/group id for low-stock bot alerts (empty = skip push)
LARK_ALERT_CHAT_ID=
# Event Subscription security (Lark dev console → Event Subscription).
# Leave empty only in local dev — required in production.
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
# H5 JSSDK script URL for 免登. Empty = variant default (feishu/lark CDN).
LARK_JSSDK_URL=
# Optional explicit overrides (leave empty to derive from LARK_VARIANT)
LARK_API_BASE=
LARK_PASSPORT_BASE=
