# ─── App ───────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=itasset
POSTGRES_PASSWORD=itasset
POSTGRES_DB=itasset
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Used by the backend (async + sync drivers)
DATABASE_URL=postgresql+psycopg://itasset:itasset@db:5432/itasset

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Object storage (MinIO, S3-compatible) ─────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=it-asset

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720

# ─── Lark / 飞书 ───────────────────────────────────────
# LARK_VARIANT controls API base + OAuth domain.
#   feishu -> open.feishu.cn / passport.feishu.cn   (国内飞书)
#   lark   -> open.larksuite.com / passport.larksuite.com (海外 Lark)
LARK_VARIANT=feishu
LARK_APP_ID=
LARK_APP_SECRET=
# Optional explicit overrides (leave empty to derive from LARK_VARIANT)
LARK_API_BASE=
LARK_PASSPORT_BASE=
