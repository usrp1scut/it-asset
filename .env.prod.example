# Copy to .env on the test server: `cp .env.prod.example .env`
# then fill the values marked CHANGE-ME. Keep .env out of git (already ignored).

# ─── App ───────────────────────────────────────────────
APP_ENV=production
# Intranet HTTP UAT: keep true so /api/auth/dev-login works (免登 needs https).
# Once you put TLS in front, flip to false.
APP_DEBUG=true
# Host port nginx publishes (browser hits http://<server-ip>:HTTP_PORT/).
HTTP_PORT=8080

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=itasset
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=itasset
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://itasset:CHANGE-ME-strong-password@db:5432/itasset

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Object storage (MinIO inside compose; or any S3-compatible cloud) ─
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE-ME-minio-access-key
S3_SECRET_KEY=CHANGE-ME-minio-secret-key
S3_BUCKET=it-asset
# AWS S3 / 阿里云 OSS need region; MinIO leave empty.
S3_REGION=
# Set false in managed cloud where the bucket is pre-provisioned and creds
# can't CreateBucket. Local MinIO: keep true.
S3_AUTO_CREATE_BUCKET=true

# ─── Auth ──────────────────────────────────────────────
# Regenerate with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE-ME-regenerate-do-not-leave-default
JWT_EXPIRE_MINUTES=720

# ─── Lark / 飞书 ───────────────────────────────────────
# In the intranet-HTTP phase 免登 won't work (the Lark client requires https
# for requestAuthCode). These values are still safe to fill; they kick in
# once you switch to https. Leaving empty disables both 免登 and webhook.
LARK_VARIANT=lark
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ALERT_CHAT_ID=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
LARK_JSSDK_URL=
LARK_API_BASE=
LARK_PASSPORT_BASE=
