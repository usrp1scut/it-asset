# Copy to .env on the test server: `cp .env.prod.example .env`
# then fill the values marked CHANGE-ME. Keep .env out of git (already ignored).

# ─── App ───────────────────────────────────────────────
APP_ENV=production
# MUST be false in production — true would also re-enable /api/auth/dev-login
# (the "type any email to become anyone" debug path). Login is via password
# or Lark 免登 only.
APP_DEBUG=false
# Host port nginx publishes (browser hits http://<server-ip>:HTTP_PORT/).
HTTP_PORT=8080

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=itasset
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=itasset
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://itasset:CHANGE-ME-strong-password@db:5432/itasset

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Object storage (MinIO inside compose; or any S3-compatible cloud) ─
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE-ME-minio-access-key
S3_SECRET_KEY=CHANGE-ME-minio-secret-key
S3_BUCKET=it-asset
# AWS S3 / 阿里云 OSS need region; MinIO leave empty.
S3_REGION=
# Set false in managed cloud where the bucket is pre-provisioned and creds
# can't CreateBucket. Local MinIO: keep true.
S3_AUTO_CREATE_BUCKET=true

# ─── Auth ──────────────────────────────────────────────
# Regenerate with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE-ME-regenerate-do-not-leave-default
JWT_EXPIRE_MINUTES=720
# First-run admin bootstrap: backend creates this user (it_admin) on startup
# if it doesn't exist. Idempotent — safe to keep the values after creation.
# Login from /login with these credentials, then 修改密码 (or use the API).
INITIAL_ADMIN_EMAIL=CHANGE-ME@yourco.com
INITIAL_ADMIN_PASSWORD=CHANGE-ME-strong-initial-password
INITIAL_ADMIN_NAME=管理员

# Public base URL used to encode QR codes as deep links so 扫码即跳转。
# 必须是用户能从手机/Lark 客户端访问到的地址 —— 如 http://<服务器IP>:8080
# 或 https://<你们的域名>。空值时 QR 只编资产编号文本,扫码无法跳转。
PUBLIC_BASE_URL=

# ─── Lark / 飞书 ───────────────────────────────────────
# 内网 HTTP 也能 Lark 免登 —— Lark 客户端只要能访问 HTTP_PORT 这个内网入口,
# 并且 Lark 开发者后台「重定向 URL」精确含 /login 路径即可。空 = 关闭。
LARK_VARIANT=lark
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ALERT_CHAT_ID=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
LARK_JSSDK_URL=
LARK_API_BASE=
LARK_PASSPORT_BASE=
